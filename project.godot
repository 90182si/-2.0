; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="无限地图"
run/main_scene="uid://bcrtwm1jv1lli"
config/features=PackedStringArray("4.6", "Forward Plus")
config/icon="res://icon.svg"

[autoload]

SwDefine="uid://ceq3j2fx1hgap"
SwObjectPool="*uid://onkk3u0cap7s"
SwCrashLogger="*res://sw_crash_logger.gd"
SwCommon="*uid://d3s671y2ttvwt"

[debug]

file_logging/enable_file_logging=true
settings/gdscript/always_track_call_stacks=true
settings/gdscript/always_track_local_variables=true

[display]

window/vsync/vsync_mode=2

[editor]

movie_writer/movie_file="J:/godot/无限地图/aaa.avi"

[editor_plugins]

enabled=PackedStringArray("res://addons/Todo_Manager/plugin.cfg")

[global_group]

SWLayer="图层"

